# Build-time secrets — baked into compiled binaries via scripts/compile.ts
# Copy this file to .env.build and fill in your keys.
# .env.build is gitignored and never committed.

# Resend (fallback email delivery)
RESEND_API_KEY=

# Amazon SES (primary email delivery)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
